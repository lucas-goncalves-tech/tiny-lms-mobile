{
  "expo": {
    "name": "Tiny LMS",
    "slug": "tiny-lms",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/ios-light.png",
    "scheme": "tinylms",
    "backgroundColor": "#050406",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.drummonds.tinylms",
      "supportsTablet": true
    },
    "android": {
      "package": "com.drummonds.tinylms",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#050406",
          "dark": {
            "backgroundColor": "#050406"
          }
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
